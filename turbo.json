{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "start": {
      "persistent": true,
      "cache": false,
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist"]
    },
    "test": {},
    "lint": {},
    "lint:autofix": {},
    "format:check": {},
    "format:write": {}
  },
  "globalDependencies": ["tsconfig.json"]
}
